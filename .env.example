MI_USUARIO=""
MI_CONTRASENA=""

DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# ── Discord Bot ──────────────────────────────────────────────────────────────
# Token del bot (Discord Developer Portal → Bot → Token)
DISCORD_BOT_TOKEN=

# ID de tu servidor (clic derecho al servidor → "Copiar ID del servidor")
# Opcional: si lo defines, los slash commands se registran al instante en ese servidor.
# Si lo dejas vacío, los comandos se registran globalmente (puede tardar ~1h).
DISCORD_GUILD_ID=

# Tu ID de usuario en Discord (Ajustes → Avanzado → activa "Modo desarrollador",
# luego clic derecho en tu avatar → "Copiar ID de usuario")
# Deja vacío para permitir que cualquiera use el bot.
DISCORD_OWNER_ID=

# UUID del usuario OSM en tu base de datos (tabla 'users')
OSM_USER_ID=

# ── Notificaciones automáticas ────────────────────────────────────────────────
# ID del canal donde el bot enviará alertas de timers.
# Clic derecho en el canal → "Copiar ID del canal" (requiere Modo desarrollador)
# Deja vacío para desactivar notificaciones.
DISCORD_ALERT_CHANNEL_ID=

# Minutos antes de que un timer expire para enviar aviso previo (default: 30)
TIMER_WARNING_MINUTES=30

# Cada cuántos minutos el bot revisa los timers en background (default: 20)
# Valores bajos aumentan el uso de CPU/RAM (cada check abre Chromium).
TIMER_CHECK_MINUTES=20

# Si un evento de bonus empieza en menos de estas horas, se espera antes de automatizar (default: 2)
EVENT_DELAY_HOURS=2

# ── Agentes IA (LLM) ──────────────────────────────────────────────────────────
# Proveedor de LLM: "auto" intenta Ollama primero y usa Anthropic como fallback.
# "ollama" = solo local | "anthropic" = solo nube
LLM_PROVIDER=auto

# Ollama (local, recomendado para Orange Pi 5)
# Instalar: curl -fsSL https://ollama.ai/install.sh | sh
# Modelos recomendados para 8GB RAM:
#   phi3.5       (~2.3GB) — rápido, buen razonamiento, ideal para Orange Pi
#   llama3.2:3b  (~2.0GB) — muy ligero, multilingüe
#   mistral:7b   (~4.1GB) — mayor calidad, usa más RAM
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3.5

# Activar el loop autónomo del agente de transferibles (default: false — requiere Ollama corriendo)
# Cuando esté listo: cambiar a true
ENABLE_AGENT_LOOP=false

# Anthropic Claude (fallback en la nube, requiere API key)
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001